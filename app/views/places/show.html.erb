<h1 class="mb-4"><%= @place["name"] %></h1>

<h2 class="mb-3">My Entries</h2>

<div class="row row-cols-1 row-cols-lg-3 g-4 mb-4">
  <% for entry in @entries %>
    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title text-primary"><%= entry["title"] %></h5>
          <h6 class="card-subtitle mb-2 text-muted small"><%= entry["occurred_on"] %></h6>
          <p class="card-text mt-3"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="d-flex gap-2">
  <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Entry</a>
  <a href="/places" class="btn btn-outline-secondary">Back to All Places</a>
</div>
