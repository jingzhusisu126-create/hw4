<h1 class="mb-4">New Entry</h1>

<form action="/entries" method="post" class="shadow-sm p-4 bg-light rounded">
  <input type="hidden" name="place_id" value="<%= params["place_id"] %>">

  <div class="mb-3">
    <label for="title_input" class="form-label">Title</label>
    <input type="text" name="title" id="title_input" class="form-control" required>
  </div>

  <div class="mb-3">
    <label for="description_input" class="form-label">Description</label>
    <textarea name="description" id="description_input" class="form-control" rows="3"></textarea>
  </div>

  <div class="mb-3">
    <label for="occurred_on_input" class="form-label">Occurred On</label>
    <input type="date" name="occurred_on" id="occurred_on_input" class="form-control" required>
  </div>

  <button class="btn btn-primary">Save</button>
  <a href="/places/<%= params["place_id"] %>" class="btn btn-outline-secondary">Cancel</a>
</form>
