<nav>
  <% @current_user = User.find_by({ "id" => session["user_id"] }) %>
  <% if @current_user %>
    <p>
      Logged in as: <%= @current_user["username"] %> | 
      <a href="/logout">Logout</a>
    </p>
  <% else %>
    <p>
      <a href="/sessions/new">Login</a> | <a href="/users/new">Sign Up</a>
    </p>
  <% end %>
</nav>

<p><%= flash["notice"] %></p>
